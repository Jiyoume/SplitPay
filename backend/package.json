{
  "name": "splitpay-backend",
  "version": "1.0.0",
  "private": true,
  "description": "SplitPay backend API — Fastify + SQLite + Stellar testnet settlement",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/domain/netting.test.ts"
  },
  "dependencies": {
    "@fastify/jwt": "^8.0.0",
    "@stellar/stellar-sdk": "^16.0.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fastify-type-provider-zod": "^2.1.0",
    "tesseract.js": "^5.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.15",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
