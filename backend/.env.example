# SplitPay backend — environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# PostgreSQL database connection string (e.g. from Supabase)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# JWT signing key — must be at least 32 characters. Generate e.g. with:
#   openssl rand -hex 32
JWT_SECRET=__set_me__
JWT_EXPIRES_IN=7d

# AES-256-GCM key used to encrypt custodial Stellar secret keys at rest.
# Must be EXACTLY 32 bytes, hex-encoded (64 hex chars). Generate with:
#   openssl rand -hex 32
# WARNING: changing this key after wallets are provisioned makes existing
# wallets' secrets undecryptable (unspendable). On testnet, the fix is to
# re-provision (re-register) — there is no recovery path for the old key.
WALLET_ENCRYPTION_KEY=__set_me_openssl_rand_hex_32__

STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
FRIENDBOT_URL=https://friendbot.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_TX_TIMEOUT_SECONDS=30
HORIZON_TIMEOUT_MS=30000
USER_BALANCE_FETCH_TIMEOUT_MS=2000
HORIZON_POLL_INTERVAL_MS=2000

LOG_LEVEL=info
CORS_ORIGIN=*
