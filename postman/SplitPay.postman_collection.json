{
  "info": {
    "name": "SplitPay API - Test Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection covering the 16 API endpoints exercised by integration tests (integration.test.ts)."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth / Register",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/auth/register", "host": [ "{{baseUrl}}" ], "path": [ "auth", "register" ] }
      }
    },
    {
      "name": "Auth / Login",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/auth/login", "host": [ "{{baseUrl}}" ], "path": [ "auth", "login" ] }
      }
    },
    {
      "name": "Users / GET /users/me",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/users/me", "host": [ "{{baseUrl}}" ], "path": [ "users", "me" ] }
      }
    },
    {
      "name": "Users / GET /users/me/summary",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/users/me/summary", "host": [ "{{baseUrl}}" ], "path": [ "users", "me", "summary" ] }
      }
    },
    {
      "name": "Wallet / POST /users/me/wallet/fund",
      "request": {
        "method": "POST",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/users/me/wallet/fund", "host": [ "{{baseUrl}}" ], "path": [ "users", "me", "wallet", "fund" ] }
      }
    },
    {
      "name": "Groups / GET /groups",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/groups", "host": [ "{{baseUrl}}" ], "path": [ "groups" ] }
      }
    },
    {
      "name": "Groups / POST /groups",
      "request": {
        "method": "POST",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test Group\",\n  \"description\": \"A test group\",\n  \"type\": \"friends\",\n  \"memberEmails\": [\"user2@example.com\"]\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/groups", "host": [ "{{baseUrl}}" ], "path": [ "groups" ] }
      }
    },
    {
      "name": "Groups / GET /groups/:id",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/groups/{{groupId}}", "host": [ "{{baseUrl}}" ], "path": [ "groups", "{{groupId}}" ] }
      }
    },
    {
      "name": "Groups / GET /groups/:id/expenses",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/groups/{{groupId}}/expenses", "host": [ "{{baseUrl}}" ], "path": [ "groups", "{{groupId}}", "expenses" ] }
      }
    },
    {
      "name": "Groups / POST /groups/:id/expenses (equal)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"description\": \"Dinner\",\n  \"amount\": 100,\n  \"currency\": \"USD\",\n  \"category\": \"food\",\n  \"splitMethod\": \"equal\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/groups/{{groupId}}/expenses", "host": [ "{{baseUrl}}" ], "path": [ "groups", "{{groupId}}", "expenses" ] }
      }
    },
    {
      "name": "Groups / POST /groups/:id/expenses (exact)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"description\": \"Lunch\",\n  \"amount\": 50,\n  \"currency\": \"USD\",\n  \"category\": \"food\",\n  \"splitMethod\": \"exact\",\n  \"splits\": [\n    { \"userId\": \"{{userId1}}\", \"amount\": 25 },\n    { \"userId\": \"{{userId2}}\", \"amount\": 25 }\n  ]\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/groups/{{groupId}}/expenses", "host": [ "{{baseUrl}}" ], "path": [ "groups", "{{groupId}}", "expenses" ] }
      }
    },
    {
      "name": "Groups / GET /groups/:id/balances",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/groups/{{groupId}}/balances", "host": [ "{{baseUrl}}" ], "path": [ "groups", "{{groupId}}", "balances" ] }
      }
    },
    {
      "name": "Groups / POST /groups/:id/settlements",
      "request": {
        "method": "POST",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fromUserId\": \"{{userId2}}\",\n  \"toUserId\": \"{{userId1}}\",\n  \"amount\": 10,\n  \"currency\": \"USD\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/groups/{{groupId}}/settlements", "host": [ "{{baseUrl}}" ], "path": [ "groups", "{{groupId}}", "settlements" ] }
      }
    },
    {
      "name": "Groups / GET /groups/:id/settlements",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/groups/{{groupId}}/settlements", "host": [ "{{baseUrl}}" ], "path": [ "groups", "{{groupId}}", "settlements" ] }
      }
    },
    {
      "name": "Settlements / GET /settlements/:id",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/settlements/{{settlementId}}", "host": [ "{{baseUrl}}" ], "path": [ "settlements", "{{settlementId}}" ] }
      }
    },
    {
      "name": "Activity / GET /activity",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/activity", "host": [ "{{baseUrl}}" ], "path": [ "activity" ] }
      }
    },
    {
      "name": "Health / GET /health",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/health", "host": [ "{{baseUrl}}" ], "path": [ "health" ] }
      }
    }
  ]
}
