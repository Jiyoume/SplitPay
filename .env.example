# ============================================
# MyShare - Environment Variables
# ============================================

# ===== SUPABASE =====
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ===== STELLAR =====
EXPO_PUBLIC_STELLAR_NETWORK=testnet
EXPO_PUBLIC_STELLAR_ANCHOR_DOMAIN=testanchor.stellar.org
EXPO_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# ===== GOOGLE CLOUD VISION (OCR) =====
EXPO_PUBLIC_GOOGLE_VISION_KEY=your-google-vision-api-key

# ===== AWS REKOGNITION (Face Recognition) =====
EXPO_PUBLIC_AWS_REGION=ap-southeast-1
EXPO_PUBLIC_AWS_ACCESS_KEY=your-aws-access-key
EXPO_PUBLIC_AWS_SECRET_KEY=your-aws-secret-key

# ===== PAYMONGO (GCash + Maya Payments) =====
EXPO_PUBLIC_PAYMONGO_PUBLIC=pk_test_your-public-key
EXPO_PUBLIC_PAYMONGO_SECRET=sk_test_your-secret-key

# ===== SEMAPHORE (SMS OTP - Philippines) =====
EXPO_PUBLIC_SEMAPHORE_KEY=your-semaphore-api-key

# ===== PUSH NOTIFICATIONS =====
EXPO_PUBLIC_FCM_SERVER_KEY=your-fcm-server-key

# ===== APP =====
EXPO_PUBLIC_APP_NAME=MyShare
EXPO_PUBLIC_APP_URL=http://localhost:5000
EXPO_PUBLIC_API_URL=http://localhost:3001
