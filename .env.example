# ============================================
# MyShare - Environment Variables
# ============================================
# Copy this file to .env and fill in your credentials
# Get Supabase keys: https://supabase.com/dashboard → Settings → API
# Get Firebase keys: https://console.firebase.google.com → Project Settings
# ============================================

# ===== SUPABASE (Authentication) =====
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-anon-key

# ===== FIREBASE (Data & Storage) =====
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSy...your-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:000000000000

# ===== STELLAR (Blockchain) =====
EXPO_PUBLIC_STELLAR_NETWORK=testnet
EXPO_PUBLIC_STELLAR_ANCHOR_DOMAIN=testanchor.stellar.org
EXPO_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# ===== APP CONFIG =====
EXPO_PUBLIC_APP_NAME=MyShare
EXPO_PUBLIC_APP_URL=https://jiyoume.github.io/SplitPay
